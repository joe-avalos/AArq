---
import Page from '../layouts/Page.astro';
import Carousel from '../components/Carousel.astro';
import { ui } from '../i18n/ui';

const slides = [
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-16-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-1-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-2-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-3-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-4-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-5-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-6-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-7-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-8-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-10-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-11-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-12-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-13-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-14-min.jpg',
  'https://avalosarquitectos.com/public/content/homepage/homepage-slider-15-min.jpg',
];
---

<Page
  title="Home"
  description="Avalos Arquitectos y Asociados — Architecture firm in Cabo San Lucas, Mexico. Over 40 years creating lifestyles."
  headerVariant="home"
  showFooter={false}
  preloadImage="https://avalosarquitectos.com/public/content/homepage/homepage-slider-1-min.jpg"
>
  <div class="hero">
    <Carousel label={ui.en.carousel_aria} autoplay={true} fullscreen={true}>
      {slides.map((src, i) => (
        <div
          class="hero-slide"
          role="group"
          aria-roledescription="slide"
          aria-label={`${ui.en.carousel_slide} ${i + 1}`}
          style={`background-image: url(${src})`}
        ></div>
      ))}
    </Carousel>
    <div class="hero-overlay">
      <p class="hero-tagline">
        <span lang="en">{ui.en.hero_tagline}</span>
        <span lang="es">{ui.es.hero_tagline}</span>
      </p>
    </div>
  </div>
</Page>

<style>
  .hero {
    position: relative;
    height: 100vh;
    margin-top: calc(-1 * var(--header-height));
    width: 100%;
  }

  .hero-slide {
    flex: 0 0 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    scroll-snap-align: start;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.3), rgba(0, 0, 0, 0.5));
    z-index: 1;
    pointer-events: none;
  }

  .hero-tagline {
    color: #ffffff;
    font-family: var(--font-heading);
    font-weight: var(--font-weight-light);
    font-size: var(--text-hero);
    line-height: 1.1;
    max-width: 800px;
    padding-inline: var(--space-md);
  }
</style>
