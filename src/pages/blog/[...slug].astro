---
import { getCollection, render } from 'astro:content';
import Blog from '../../layouts/Blog.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('blog');

  // Group all entries by slug
  const bySlug = new Map<string, typeof allPosts>();
  for (const post of allPosts) {
    if (!bySlug.has(post.data.slug)) {
      bySlug.set(post.data.slug, []);
    }
    bySlug.get(post.data.slug)!.push(post);
  }

  // Emit one path per unique slug
  return [...bySlug.entries()].map(([slug, entries]) => ({
    params: { slug },
    props: { entries },
  }));
}

const { entries } = Astro.props;

// Separate EN and ES entries
const enEntry = entries.find((e: { data: { lang: string } }) => e.data.lang === 'en') ?? entries[0];
const esEntry = entries.find((e: { data: { lang: string } }) => e.data.lang === 'es');

const { Content: EnContent } = await render(enEntry);
const esRendered = esEntry ? await render(esEntry) : null;
const EsContent = esRendered?.Content;

// Use EN entry for page metadata
const { title, date, excerpt } = enEntry.data;
const description = excerpt;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: 'Avalos Arquitectos y Asociados',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Avalos Arquitectos y Asociados',
    logo: {
      '@type': 'ImageObject',
      url: 'https://avalosarquitectos.com/public/images/logo.jpeg',
    },
  },
};
---

<Blog title={title} description={description} date={date}>
  <div lang="en" class="content-block">
    <EnContent />
  </div>
  {EsContent && (
    <div lang="es" class="content-block">
      <EsContent />
    </div>
  )}
</Blog>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

<style>
  .content-block {
    /* Visibility is controlled by html[lang] selector in global CSS */
  }
</style>
