---
import { getCollection } from 'astro:content';
import Page from '../../layouts/Page.astro';
import BlogList from '../../components/BlogList.astro';
import { ui } from '../../i18n/ui';

const allPosts = await getCollection('blog');

// Deduplicate: group by slug, take EN entry for each
const postsBySlug = new Map();
for (const post of allPosts) {
  if (post.data.lang === 'en' || !postsBySlug.has(post.data.slug)) {
    postsBySlug.set(post.data.slug, post);
  }
}
const posts = [...postsBySlug.values()].sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Page title="News" description="Latest news from Avalos Arquitectos y Asociados">
  <section class="section max-width">
    <h1 class="page-title">
      <span lang="en">{ui.en.blog_title}</span>
      <span lang="es">{ui.es.blog_title}</span>
    </h1>
    <BlogList posts={posts} />
  </section>
</Page>

<style>
  .max-width {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: var(--space-md, 1.5rem);
  }

  .section {
    padding-block: var(--space-xl, 3rem) var(--space-2xl, 4rem);
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-block: 0 var(--space-lg, 2rem);
    color: var(--color-text-primary);
  }
</style>
