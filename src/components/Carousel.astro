---
import { ui } from '../i18n/ui';

interface Props {
  label: string;
  autoplay?: boolean;
  fullscreen?: boolean;
}

const { label, autoplay = false, fullscreen = false } = Astro.props;
const t = ui;
---

<div
  class:list={['carousel', { 'carousel-fullscreen': fullscreen }]}
  role="region"
  aria-roledescription="carousel"
  aria-label={label}
  data-autoplay={autoplay ? 'true' : 'false'}
>
  <div class="carousel-track">
    <slot />
  </div>

  <button class="carousel-prev" type="button" aria-label={t.en.carousel_prev}>
    <span lang="en">{t.en.carousel_prev}</span><span lang="es">{t.es.carousel_prev}</span>
    <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <button class="carousel-next" type="button" aria-label={t.en.carousel_next}>
    <span lang="en">{t.en.carousel_next}</span><span lang="es">{t.es.carousel_next}</span>
    <svg aria-hidden="true" focusable="false" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <div class="carousel-dots" role="tablist" aria-label="Slide navigation"></div>
</div>

<style>
  .carousel {
    position: relative;
    overflow: hidden;
  }

  .carousel-fullscreen {
    width: 100%;
    height: 100vh;
    height: 100dvh;
  }

  .carousel-track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    height: 100%;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  /* Slides inserted via <slot> */
  .carousel-track > :global(*) {
    flex: 0 0 100%;
    scroll-snap-align: start;
    height: 100%;
  }

  /* Prev / Next buttons */
  .carousel-prev,
  .carousel-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    background: rgba(0, 0, 0, 0.45);
    color: #ffffff;
    transition: background 0.2s ease;
    /* Hide label text visually, keep for screen readers */
    font-size: 0;
  }

  .carousel-prev {
    left: var(--space-sm, 0.75rem);
  }

  .carousel-next {
    right: var(--space-sm, 0.75rem);
  }

  @media (hover: hover) {
    .carousel-prev:hover,
    .carousel-next:hover {
      background: rgba(0, 0, 0, 0.72);
    }
  }

  .carousel-prev:active,
  .carousel-next:active {
    background: rgba(0, 0, 0, 0.72);
  }

  .carousel-prev svg,
  .carousel-next svg {
    flex-shrink: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-prev,
    .carousel-next {
      display: none;
    }
  }

  /* Dots */
  .carousel-dots {
    position: absolute;
    bottom: var(--space-sm, 0.75rem);
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: row;
    gap: 8px;
    z-index: 2;
  }

  .carousel-dots button {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    padding: 8px;
    background-clip: content-box;
    background-color: var(--color-border, rgba(255, 255, 255, 0.45));
    transition: background-color 0.2s ease;
  }

  .carousel-dots button[aria-selected='true'] {
    background-color: var(--color-accent, #ffffff);
  }

  /* In fullscreen context, always use white dots */
  .carousel-fullscreen .carousel-dots button {
    background-color: rgba(255, 255, 255, 0.45);
  }

  .carousel-fullscreen .carousel-dots button[aria-selected='true'] {
    background-color: #ffffff;
  }
</style>

<style is:global>
  /* ---- Mobile lightbox overlay ---- */
  .lightbox-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.92);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: zoom-out;
    padding: var(--space-sm, 0.75rem);
  }

  .lightbox-overlay[hidden] {
    display: none;
  }

  .lightbox-close {
    position: absolute;
    top: var(--space-sm, 0.75rem);
    right: var(--space-sm, 0.75rem);
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    color: #fff;
    font-size: 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
  }
</style>

<script>
  import { Carousel } from '../js/carousel.js';
  import { initLightbox } from '../js/lightbox.js';

  document.querySelectorAll('.carousel').forEach((el) => {
    const autoplay = (el as HTMLElement).dataset.autoplay === 'true';
    new Carousel(el as HTMLElement, { autoplay, interval: 5000 });
    initLightbox(el as HTMLElement);
  });
</script>
