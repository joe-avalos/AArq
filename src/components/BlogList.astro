---
import { ui } from '../i18n/ui';

interface Post {
  id: string;
  data: {
    title: string;
    slug: string;
    lang: 'en' | 'es';
    date: Date;
    excerpt: string;
    author?: string;
  };
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;

function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

{posts.length === 0 ? (
  <p class="blog-empty">
    <span lang="en">{ui.en.blog_empty}</span>
    <span lang="es">{ui.es.blog_empty}</span>
  </p>
) : (
  <ul class="blog-list">
    {posts.map((post) => (
      <li class="blog-item">
        <a href={`/blog/${post.data.slug}/`} class="blog-item-link">
          <time class="blog-item-date" datetime={post.data.date.toISOString()}>
            {formatDate(post.data.date)}
          </time>
          <h2 class="blog-item-title">{post.data.title}</h2>
          <p class="blog-item-excerpt">{post.data.excerpt}</p>
        </a>
      </li>
    ))}
  </ul>
)}

<style>
  .blog-empty {
    font-size: 1rem;
    color: var(--color-text-secondary, #6b7280);
    padding-block: var(--space-xl, 3rem);
  }

  .blog-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .blog-item {
    border-top: 1px solid var(--color-border, #e5e7eb);
  }

  .blog-item:last-child {
    border-bottom: 1px solid var(--color-border, #e5e7eb);
  }

  .blog-item-link {
    display: block;
    padding-block: var(--space-lg, 2rem);
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s ease;
  }

  .blog-item-link:hover,
  .blog-item-link:focus-visible {
    opacity: 0.7;
  }

  .blog-item-date {
    display: block;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary, #6b7280);
    margin-block-end: var(--space-xs, 0.5rem);
  }

  .blog-item-title {
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    font-weight: 300;
    letter-spacing: 0.03em;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-xs, 0.5rem);
    line-height: 1.3;
  }

  .blog-item-excerpt {
    font-size: 0.95rem;
    line-height: 1.65;
    color: var(--color-text-secondary, #6b7280);
    margin: 0;
    max-width: 72ch;
  }
</style>
