---
import { ui } from '../i18n/ui';

interface Props {
  projects: any[];
}

const { projects } = Astro.props;

const filters = [
  { key: 'all',              labelEn: ui.en.filter_all,         labelEs: ui.es.filter_all },
  { key: 'residential',      labelEn: ui.en.filter_residential, labelEs: ui.es.filter_residential },
  { key: 'commercial',       labelEn: ui.en.filter_commercial,  labelEs: ui.es.filter_commercial },
  { key: 'arts_and_culture', labelEn: ui.en.filter_arts,        labelEs: ui.es.filter_arts },
  { key: 'places_of_worship',labelEn: ui.en.filter_worship,     labelEs: ui.es.filter_worship },
];
---

<div class="project-filter">
  <!-- Filter tabs -->
  <div class="filter-tabs" role="tablist">
    {filters.map((f, i) => (
      <button
        type="button"
        role="tab"
        aria-selected={i === 0 ? 'true' : 'false'}
        data-filter={f.key}
      >
        <span lang="en">{f.labelEn}</span><span lang="es">{f.labelEs}</span>
      </button>
    ))}
  </div>

  <!-- Project grid -->
  <div class="project-grid">
    {projects.map((project) => (
      <div class="card-wrapper" data-category={project.data.category}>
        <a href={`/projects/${project.id}/`} class="project-card">
          <img
            src={project.data.thumbnail}
            alt={project.data.title}
            loading="lazy"
            width="600"
            height="450"
          />
          <div class="project-card-info">
            <p class="project-card-title">{project.data.title}</p>
            <p class="project-card-location">{project.data.location}</p>
          </div>
        </a>
      </div>
    ))}
  </div>
</div>

<style>
  .filter-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs, 0.5rem);
    margin-bottom: var(--space-md, 1.5rem);
  }

  @media (max-width: 600px) {
    .filter-tabs {
      flex-wrap: nowrap;
      overflow-x: auto;
      scrollbar-width: none;
      gap: 0;
      mask-image: linear-gradient(to right, black 0, black calc(100% - 1.5rem), transparent 100%);
      -webkit-mask-image: linear-gradient(to right, black 0, black calc(100% - 1.5rem), transparent 100%);
      padding-inline-end: 1.5rem;
    }
    .filter-tabs::-webkit-scrollbar {
      display: none;
    }
  }

  .filter-tabs button {
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.375rem 0;
    margin-inline-end: var(--space-xs, 0.5rem);
    font-size: var(--text-xs, 0.75rem);
    font-family: inherit;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted, #6b6b6b);
    cursor: pointer;
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .filter-tabs button:hover {
      color: var(--color-text, #1a1a1a);
    }
  }
  .filter-tabs button:active {
    color: var(--color-text, #1a1a1a);
  }

  .filter-tabs button[aria-selected='true'] {
    color: var(--color-text, #1a1a1a);
    border-bottom-color: var(--color-accent, #1a1a1a);
  }

  .project-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md, 1.5rem);
  }

  .card-wrapper {
    width: calc(33.333% - var(--space-md, 1.5rem) * 2 / 3);
    overflow: hidden;
    transition: width 0.4s ease, opacity 0.3s ease, margin 0.4s ease, padding 0.4s ease;
  }

  @media (max-width: 960px) {
    .card-wrapper {
      width: calc(50% - var(--space-md, 1.5rem) / 2);
    }
  }

  @media (max-width: 600px) {
    .card-wrapper {
      width: 100%;
    }
  }

  .card-wrapper.hiding {
    width: 0;
    opacity: 0;
    margin: 0;
    padding: 0;
  }

  .card-wrapper.hidden {
    display: none;
  }

  .project-card {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4 / 3;
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--color-surface, #f5f5f5);
    width: 100%;
  }

  .project-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  @media (hover: hover) {
    .project-card:hover img {
      transform: scale(1.04);
    }
  }

  .project-card-info {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-sm, 0.75rem) var(--space-md, 1.5rem);
    background: linear-gradient(to top, rgba(0, 0, 0, 0.72) 0%, transparent 100%);
    color: #ffffff;
  }

  .project-card-title {
    margin: 0;
    font-size: var(--text-sm, 0.875rem);
    font-weight: 600;
    line-height: 1.3;
  }

  .project-card-location {
    margin: 0.25rem 0 0;
    font-size: var(--text-xs, 0.75rem);
    opacity: 0.85;
  }

  /* .hidden and .hiding now handled on .card-wrapper above */
</style>

<script>
  import { initFilter } from '../js/filter.js';
  const container = document.querySelector('.project-filter');
  if (container) initFilter(container as HTMLElement);
</script>
