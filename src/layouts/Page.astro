---
import Base from './Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  preloadImage?: string;
  active?: 'projects' | 'services' | 'about' | 'contact';
  headerVariant?: 'home' | 'page';
  showFooter?: boolean;
}

const {
  title,
  description,
  ogImage,
  preloadImage,
  active,
  headerVariant = 'page',
  showFooter = true,
} = Astro.props;
---

<Base title={title} description={description} ogImage={ogImage} preloadImage={preloadImage}>
  <Header active={active} variant={headerVariant} />
  <main id="main-content">
    <slot />
  </main>
  {showFooter && <Footer />}
</Base>
